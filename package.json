{
  "name": "@jamesmurdza/sbx",
  "version": "0.1.0",
  "description": "Run sandboxed AI coding agents in fresh Daytona sandboxes, with credential import, auto git push, and detach/reconnect.",
  "type": "module",
  "bin": {
    "sbx": "./bin/sbx.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node --test --import tsx ./test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node bin/sbx.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@daytonaio/sdk": "^0.110.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
